<!DOCTYPE html>
<html>

<head>
    <title>Error</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f8d7da;
            color: #721c24;
            padding: 40px;
        }

        .container {
            background: #fff;
            border-radius: 8px;
            padding: 24px;
            max-width: 500px;
            margin: auto;
            box-shadow: 0 2px 8px #ccc;
        }

        h1 {
            color: #721c24;
        }

        p {
            margin-top: 16px;
        }
    </style>
</head>

<body>
    <div class="container">
        <h1>Error</h1>
        <p>
            <%= message %>
        </p>
        <% if (error && error.status) { %>
            <p>Status: <%= error.status %>
            </p>
            <% } %>
                <% if (error && error.stack) { %>
                    <pre><%= error.stack %></pre>
                    <% } %>
    </div>
</body>

</html>